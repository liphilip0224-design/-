rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: results
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user's unique ID.
    //   - email: string (optional) - The user's email address.
    //   - timestamp: timestamp (required) - When the assessment was completed.
    //   - scores: map (required) - The raw scores for each sub-dimension.
    //   - portrait: map (required) - The generated portrait title and subtitle.
    //   - mostSuitable: string (optional) - The most suitable work structure.
    //   - leastSuitable: string (optional) - The least suitable work structure.
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required) - The user's unique ID.
    //   - email: string (required) - The user's email address.
    //   - role: string (required, ['admin', 'user']) - The user's role.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "liphilip0224@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidResult(data) {
      return data.keys().hasAll(['uid', 'timestamp', 'scores', 'portrait']) &&
             data.uid is string &&
             data.timestamp is timestamp &&
             data.scores is map &&
             data.portrait is map &&
             data.portrait.keys().hasAll(['title', 'subtitle']) &&
             data.portrait.title is string &&
             data.portrait.subtitle is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /results/{resultId} {
      // Users can create their own results
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidResult(request.resource.data);
      
      // Users can read their own results
      allow read: if isAuthenticated() && 
                    (resource.data.uid == request.auth.uid || isAdmin());
      
      // Only admins can delete results
      allow delete: if isAdmin();
      
      // Results are immutable for users
      allow update: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile as 'user' role
      allow create: if isOwner(userId) && 
                      request.resource.data.role == 'user' &&
                      isValidUser(request.resource.data);
      
      // Only admins can update roles
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }
  }
}
