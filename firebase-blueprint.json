{
  "entities": {
    "AssessmentResult": {
      "title": "Assessment Result",
      "description": "A single user's assessment result including scores and portrait.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the assessment was completed." },
        "scores": { "type": "object", "description": "The raw scores for each sub-dimension." },
        "portrait": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" }
          }
        },
        "mostSuitable": { "type": "string" },
        "leastSuitable": { "type": "string" }
      },
      "required": ["uid", "timestamp", "scores", "portrait"]
    },
    "User": {
      "title": "User",
      "description": "A user's profile and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/results/{resultId}": {
      "schema": "AssessmentResult",
      "description": "Collection of all assessment results."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and roles."
    }
  }
}
